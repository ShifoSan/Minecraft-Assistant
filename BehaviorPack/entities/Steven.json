{
    "format_version": "1.21.0",
    "minecraft:entity": {
        "description": {
            "identifier": "shifolabs:steven",
            "is_spawnable": true,
            "is_summonable": true,
            "properties": {
                "steven:follow_distance": {
                    "type": "int",
                    "default": 3,
                    "range": [ 1, 100 ]
                }
            }
        },
        "component_groups": {
            "steven:following": {
                "minecraft:behavior.follow_owner": {
                    "priority": 3,
                    "speed_multiplier": 1.2,
                    "start_distance": "q.property('steven:follow_distance')",
                    "stop_distance": 1,
                    "postpone_distance": 20
                }
            },
            "steven:sprint_following": {
                "minecraft:behavior.follow_owner": {
                    "priority": 3,
                    "speed_multiplier": 2.0,
                    "start_distance": 1,
                    "stop_distance": 1,
                    "postpone_distance": 20
                }
            },
            "steven:staying": {
            },
            "steven:guarding": {
                "minecraft:behavior.nearest_attackable_target": {
                    "priority": 1,
                    "entity_types": [
                        { "filters": { "test": "is_family", "subject": "other", "value": "monster" }, "max_dist": 20 }
                    ],
                    "must_see": true
                },
                "minecraft:behavior.melee_attack": {
                    "priority": 2,
                    "speed_multiplier": 1.5,
                    "track_target": true
                }
            },
            "steven:guarding_return": {
            },
            "steven:protecting": {
                "minecraft:behavior.owner_hurt_by_target": {
                    "priority": 1
                },
                "minecraft:behavior.owner_hurt_target": {
                    "priority": 1
                },
                "minecraft:behavior.nearest_attackable_target": {
                    "priority": 2,
                    "entity_types": [
                        { "filters": { "test": "is_family", "subject": "other", "value": "monster" }, "max_dist": 15 }
                    ],
                    "must_see": true
                },
                "minecraft:behavior.melee_attack": {
                    "priority": 3,
                    "speed_multiplier": 1.5,
                    "track_target": true
                },
                "minecraft:behavior.follow_owner": {
                    "priority": 4,
                    "speed_multiplier": 1.2,
                    "start_distance": 5,
                    "stop_distance": 2,
                    "postpone_distance": 20
                }
            },
            "steven:distracting": {
                "minecraft:behavior.nearest_attackable_target": {
                    "priority": 1,
                    "entity_types": [
                        {
                            "filters": {
                                "all_of": [
                                    { "test": "is_family", "subject": "other", "value": "monster" },
                                    { "test": "distance_to_nearest_player", "operator": ">=", "value": 10 }
                                ]
                            },
                            "max_dist": 30
                        }
                    ],
                    "must_see": true
                },
                "minecraft:behavior.melee_attack": {
                    "priority": 2,
                    "speed_multiplier": 1.5,
                    "track_target": true
                }
            }
        },
        "components": {
            "minecraft:physics": {},
            "minecraft:collision_box": { "width": 0.6, "height": 1.8 },
            "minecraft:movement": { "value": 0.3 },
            "minecraft:movement.basic": {},
            "minecraft:jump.static": {},
            "minecraft:navigation.walk": { "can_path_over_water": true, "avoid_water": true },
            "minecraft:health": { "value": 20, "max": 20 },
            "minecraft:tameable": {
                "probability": 1.0,
                "tame_items": "minecraft:apple",
                "tame_event": {
                    "event": "steven:on_tame",
                    "target": "self"
                }
            },
            "minecraft:nameable": {},
            "minecraft:type_family": { "family": [ "shifolabs_steven", "mob" ] },
            "minecraft:behavior.look_at_player": { "priority": 1, "look_distance": 8.0 },
            "minecraft:behavior.random_look_around": { "priority": 2 },
            "minecraft:inventory": { "container_type": "inventory", "inventory_size": 27 },
            "minecraft:equippable": {
                "slots": [
                    { "slot": "slot.weapon.mainhand" },
                    { "slot": "slot.armor.head" },
                    { "slot": "slot.armor.chest" },
                    { "slot": "slot.armor.legs" },
                    { "slot": "slot.armor.feet" }
                ]
            },
            "minecraft:attack": {
                "damage": 3
            }
        },
        "events": {
            "steven:cmd_follow": {
                "add": { "component_groups": [ "steven:following" ] },
                "remove": { "component_groups": [ "steven:staying", "steven:guarding", "steven:protecting", "steven:distracting", "steven:sprint_following" ] }
            },
            "steven:cmd_sprint_follow": {
                "add": { "component_groups": [ "steven:sprint_following" ] },
                "remove": { "component_groups": [ "steven:staying", "steven:following", "steven:guarding", "steven:protecting", "steven:distracting" ] }
            },
            "steven:cmd_stay": {
                "add": { "component_groups": [ "steven:staying" ] },
                "remove": { "component_groups": [ "steven:following", "steven:guarding", "steven:protecting", "steven:distracting", "steven:sprint_following" ] }
            },
            "steven:cmd_guard": {
                "add": { "component_groups": [ "steven:guarding" ] },
                "remove": { "component_groups": [ "steven:following", "steven:staying", "steven:protecting", "steven:distracting", "steven:sprint_following" ] }
            },
            "steven:cmd_protect": {
                "add": { "component_groups": [ "steven:protecting" ] },
                "remove": { "component_groups": [ "steven:following", "steven:staying", "steven:guarding", "steven:distracting", "steven:sprint_following" ] }
            },
            "steven:cmd_distract": {
                "add": { "component_groups": [ "steven:distracting" ] },
                "remove": { "component_groups": [ "steven:following", "steven:staying", "steven:guarding", "steven:protecting", "steven:sprint_following", "steven:guarding_return" ] }
            },
            "steven:cmd_guard_return": {
                "add": { "component_groups": [ "steven:guarding_return" ] },
                "remove": { "component_groups": [ "steven:guarding" ] }
            },
            "steven:cmd_guard_resume": {
                "add": { "component_groups": [ "steven:guarding" ] },
                "remove": { "component_groups": [ "steven:guarding_return" ] }
            },
            "steven:stop_combat": {
                "remove": { "component_groups": [ "steven:guarding", "steven:protecting", "steven:distracting" ] }
            },
            "steven:on_tame": {}
        }
    }
}
