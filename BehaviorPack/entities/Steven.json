            "minecraft:movement.basic": {},
            "minecraft:jump.static": {},
            "minecraft:navigation.walk": { "can_path_over_water": true, "avoid_water": true },
            "minecraft:health": { "value": 20, "max": 20 },
            "minecraft:tameable": {
